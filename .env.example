# Optional environment overrides for the dashboard server.
# Copy to `.env` (gitignored) and edit if you need non-defaults.

# Port the Fastify API listens on. Vite dev proxy in web/vite.config.ts
# forwards /api → http://127.0.0.1:$PORT, so if you change this, change
# the proxy target too.
PORT=8790

# Bind address. Localhost-only is recommended (your JSONL transcripts
# and OAuth-derived weekly limits never leave the machine).
HOST=127.0.0.1
